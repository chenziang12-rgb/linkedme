{
  "name": "linkedme-platform",
  "private": true,
  "version": "0.1.0",
  "description": "LinkedMe – a context-aware career copilot built around a unified knowledge base for hyper-personalized job workflows.",
  "scripts": {
    "dev": "pnpm run -r --parallel dev --filter linkedme-api --filter linkedme-web",
    "build": "pnpm run -r build --filter linkedme-api --filter linkedme-web",
    "test": "pnpm run -r test --filter linkedme-api --filter linkedme-web",
    "lint": "pnpm run -r lint --filter linkedme-api --filter linkedme-web"
  },
  "workspaces": [
    "api",
    "web"
  ],
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "dependencies": {
    "openai": "^6.7.0"
  },
  "devDependencies": {
    "terser": "^5.44.1"
  }
}
